{
  "name": "code-reviewer-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript scaffold for the Frontier Pair AI PR review pipeline.",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "setup:sh": "sh scripts/setup.sh",
    "clean": "node scripts/clean-dist.mjs",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "build": "npm run clean && node node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server/cli.js",
    "serve": "npm run build && npm start",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop code-reviewer-agent",
    "pm2:logs": "pm2 logs code-reviewer-agent --lines 50 --nostream",
    "test": "node --test \"dist/**/*.test.js\"",
    "check": "npm run typecheck && npm run build && npm run test"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "volta": {
    "node": "24.14.0",
    "npm": "10.9.0"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "pm2": "^7.0.1"
  },
  "overrides": {
    "ws": "8.21.0"
  }
}
