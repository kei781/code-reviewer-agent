# Review server bind and local state
REVIEW_SERVER_HOST=127.0.0.1
REVIEW_SERVER_PORT=3000
REVIEW_SERVER_DATABASE_PATH=.data/review-server.sqlite
REVIEW_SERVER_WORKSPACE_ROOT=.workspaces

# GitHub App and webhook credentials
GITHUB_APP_ID=replace-with-github-app-id
GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/github-app.private-key.pem
GITHUB_WEBHOOK_SECRET=replace-with-random-webhook-secret

# Optional repo scope (repo-agnostic by default).
# The server reviews ANY repo the GitHub App is installed on; repo identity comes
# from each webhook payload (repository.full_name / clone_url), not from static config.
# Set this only to restrict to specific repos (comma-separated owner/repo).
# REVIEW_REPO_ALLOWLIST=kei781/sql-agent,kei781/code-reviewer-agent

# Local OAuth-authenticated Claude Code orchestrator
CLAUDE_CODE_COMMAND=claude
CLAUDE_CODE_AUTH_MODE=local-oauth

# Runtime security and policy gates
MODEL_EGRESS_ALLOWLIST=api.anthropic.com,api.openai.com
HUMAN_REVIEW_LABEL=needs-human-review
SECURITY_SENSITIVE_LABEL=security-sensitive
DO_NOT_MERGE_LABEL=do-not-merge
TRUSTED_REVIEWERS=claude[bot],claude-code[bot]
RISKY_PATH_PATTERNS=.github/workflows/**,.github/actions/**,scripts/deploy/**,infra/**,terraform/**,k8s/**,helm/**,migrations/**,db/migrations/**,auth/**,billing/**,security/**,secrets/**,*.pem,*.key,*.crt,.env,.env.*
